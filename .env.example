# Copy to .env and fill in your own key — .env is gitignored, never commit real keys.

# Used server-side only (server/summarize.ts) to generate real blurb/"what you
# need to know"/"what it means to you" summaries for TLDR articles pulled from
# the real feed (tldr.tech/design). Without this set, feed articles just show
# their headline/link with no summary — nothing is faked.
ANTHROPIC_API_KEY=
