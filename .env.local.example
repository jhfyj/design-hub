# ─────────────────────────────────────────────────────────────────────────────
# Design Hub — Local Development Environment
#
# Copy this file to .env.local and fill in the values below.
# .env.local is gitignored and never committed.
#
# cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────────────────────


# ── 1. DATABASE ───────────────────────────────────────────────────────────────
# MySQL/TiDB connection string.
# Get this from: Manus project → Settings → Secrets → DATABASE_URL
# Format: mysql://user:password@host:port/dbname?ssl={"rejectUnauthorized":true}
#
DATABASE_URL=


# ── 2. SESSION SIGNING ────────────────────────────────────────────────────────
# Secret used to sign session cookies. Any long random string works locally.
# Get from Manus: Settings → Secrets → JWT_SECRET
# Or generate your own: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
JWT_SECRET=


# ── 3. LLM / AI ───────────────────────────────────────────────────────────────
# Your Anthropic API key — used for job filtering, TLDR summarisation,
# and careers URL discovery when running outside Manus.
# Get from: https://console.anthropic.com → API Keys
#
ANTHROPIC_API_KEY=

# Leave these blank when running locally — the server falls back to
# ANTHROPIC_API_KEY automatically when these are absent.
# (On Manus these are injected automatically — do not copy them here.)
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=


# ── 4. MANUS OAUTH (login) ────────────────────────────────────────────────────
# These power the "Sign in with Manus" flow.
# Get all three from: Manus project → Settings → Secrets
#
# Note: Manus OAuth redirects back to window.location.origin after login.
# On localhost this will be http://localhost:3000 — make sure that is an
# allowed redirect URI in your Manus OAuth app settings, or login will fail.
# The app still loads and most features work without being logged in.
#
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=


# ── 5. OWNER IDENTITY ─────────────────────────────────────────────────────────
# Your Manus user openId — used to auto-assign admin role on first login.
# Get from: Manus project → Settings → Secrets → OWNER_OPEN_ID
# Optional locally — leave blank if you don't need admin features.
#
OWNER_OPEN_ID=


# ── 6. FRONTEND FORGE (optional) ─────────────────────────────────────────────
# These are Manus-internal frontend API keys. Leave blank locally —
# they only work inside the Manus platform.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
